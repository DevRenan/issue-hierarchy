<%# Use helper node_depth_padding(node) to apply padding-left inline %>
<div data-controller="tree" data-tree-node-id-value="<%= node.id %>" class="flex items-start gap-2 py-1">
  <div class="flex items-center gap-2">
    <button data-action="click->tree#toggle" aria-expanded="true" class="p-1 rounded hover:bg-gray-100 text-gray-500">
      <% if node.children.any? %>
        <svg data-tree-target="chev" class="h-4 w-4 transform transition-transform" viewBox="0 0 20 20" fill="none" stroke="currentColor">
          <path d="M6 8l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      <% else %>
        <span class="h-4 w-4 inline-block"></span>
      <% end %>
    </button>
  </div>

  <div class="flex-1">
    <div class="flex items-center justify-between gap-2">
      <div class="flex items-center gap-2">
        <a href="<%= node_path(node) %>" data-turbo-frame="content" class="block text-sm text-gray-800 hover:underline" style="<%= node_depth_padding(node) %>">
          <%= node.name %>
        </a>
        <%= content_tag :span, node.node_type, class: "text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600 ml-2" %>
      </div>

      <div class="flex items-center gap-2">
        <%= link_to "New Issue", new_issue_path(workspace_id: node.workspace_id, node_id: node.id), class: "text-xs text-blue-600 hover:underline" %>
      </div>
    </div>

    <% if node.children.any? %>
      <div data-tree-target="children" class="mt-2">
        <%= render partial: "nodes/tree", locals: { nodes: node.children } %>
      </div>
    <% end %>
  </div>
</div>

