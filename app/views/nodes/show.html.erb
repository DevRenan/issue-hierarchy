<% content_for :title, @node.name %>

<div class="space-y-4">
  <div class="bg-white border rounded-lg p-4 shadow-sm">
    <% if notice.present? %>
      <p class="py-2 px-3 bg-green-50 text-green-600 rounded-md inline-block mb-4"><%= notice %></p>
    <% end %>

    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-2xl font-bold"><%= @node.name %></h1>
        <p class="text-sm text-gray-600 mt-1"><%= @node.description %></p>
        <div class="mt-3 text-sm text-gray-700">
          <strong>Type:</strong> <span class="inline-block px-2 py-0.5 rounded-full bg-gray-100 text-gray-600"><%= @node.node_type %></span>
        </div>
      </div>

      <div class="text-right">
        <%= link_to "Edit", edit_node_path(@node), class: "px-3 py-2 bg-gray-100 rounded-md text-sm" %>
        <%= link_to "New Issue", new_issue_path(workspace_id: @node.workspace_id, node_id: @node.id), class: "px-3 py-2 bg-blue-600 text-white rounded-md text-sm ml-2" %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    <div class="lg:col-span-1">
      <% if @node.children.any? %>
        <div class="bg-white border rounded-lg p-4 shadow-sm">
          <h3 class="font-semibold mb-3">Child Nodes</h3>
          <div class="text-sm space-y-2">
            <%= render partial: "nodes/tree", locals: { nodes: @node.children } %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="lg:col-span-2">
      <div class="bg-white border rounded-lg p-4 shadow-sm">
        <h3 class="font-semibold mb-3">Issues</h3>
        <% if @node.issues.any? %>
          <div class="space-y-3">
            <% @node.issues.each do |issue| %>
              <%= render partial: "issues/issue_card", locals: { issue: issue } %>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-500">No issues for this node.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-4 flex gap-2">
    <%= link_to "Back", workspace_path(@node.workspace), data: { turbo_frame: "content" }, class: "px-3 py-2 bg-white border rounded-md text-sm" %>
    <%= button_to "Destroy", @node, method: :delete, class: "px-3 py-2 bg-red-600 text-white rounded-md text-sm", data: { turbo_confirm: "Are you sure?" } %>
  </div>
</div>
