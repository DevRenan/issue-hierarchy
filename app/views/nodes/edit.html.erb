<% content_for :title, "Edit Node" %>

<div class="max-w-2xl">
  <div class="bg-white border rounded-lg p-6 shadow-sm">
    <h1 class="text-2xl font-bold mb-4">Edit Node</h1>

    <%= render "form", node: @node %>

    <div class="mt-6 flex gap-2">
      <%= link_to "View", @node, data: { turbo_frame: "content" }, class: "px-4 py-2 bg-gray-100 rounded-md hover:bg-gray-200" %>
      <%= link_to "Back", workspace_path(@workspace), data: { turbo_frame: "content" }, class: "px-4 py-2 bg-white border rounded-md hover:bg-gray-50" %>
    </div>
  </div>
</div>
