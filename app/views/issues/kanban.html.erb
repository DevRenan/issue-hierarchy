<%# Kanban Board Main View %>
<%# Top Section: Title, Stats, Filters %>
<%# Main Section: Kanban Columns %>

<%# --- Top Section --- %>
<div class="max-w-7xl mx-auto px-2 sm:px-6 lg:px-8 py-6">
  <h1 class="text-2xl sm:text-3xl font-bold mb-4">Kanban Board</h1>

  <%= render "stats", stats: @stats %>

  <div class="mt-6 mb-4">
    <%= render "filters", nodes: @nodes, selected_node_id: @selected_node_id, start_date: @start_date, end_date: @end_date %>
  </div>
</div>

<%# --- Main Kanban Section --- %>
<div class="overflow-x-auto pb-8">
  <div class="flex gap-4 min-w-[900px] px-2 sm:px-6 lg:px-8">
    <% Issue.statuses.keys.each do |status| %>
      <%= render "kanban_column", status: status, issues: @issues_by_status[status] || [] %>
    <% end %>
  </div>
</div>
