<div id="<%= dom_id(issue) %>" class="bg-white border rounded-lg p-4 hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-3">
    <div>
      <a href="<%= issue_path(issue) %>" data-turbo-frame="content" class="text-sm font-semibold text-gray-800 hover:underline">
        <%= issue.title %>
      </a>
      <p class="text-xs text-gray-500 mt-1"><%= truncate(issue.description.to_s, length: 140) %></p>
      <div class="mt-3 flex items-center gap-2 text-xs">
        <span class="text-gray-500">Node:</span>
        <%= link_to issue.node.name, node_path(issue.node), data: { turbo_frame: "content" }, class: "text-gray-700 hover:underline" if issue.node %>
      </div>
    </div>

    <div class="text-right">
      <div class="mb-2">
        <%= status_badge(issue.status) %>
      </div>
      <div>
        <%= priority_badge(issue.priority) %>
      </div>
    </div>
  </div>

  <div class="mt-3 flex items-center justify-between text-xs text-gray-500">
    <span>Updated <%= time_ago_in_words(issue.updated_at) %> ago</span>
    <div class="flex items-center gap-2">
      <span><%= issue.comments.count %> comments</span>
      <span><%= issue.attachments.count %> files</span>
    </div>
  </div>
</div>

