<%= form_with(model: issue, local: true) do |form| %>
  <% if issue.errors.any? %>
    <div class="bg-red-50 text-red-600 px-3 py-2 rounded-md mb-4">
      <h2 class="font-semibold"><%= pluralize(issue.errors.count, "error") %> prohibited this issue from being saved:</h2>
      <ul class="list-disc ml-6 mt-2">
        <% issue.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= form.label :workspace_id %>
      <%= form.select :workspace_id, Workspace.pluck(:name, :id), { include_blank: true }, class: "block w-full border rounded-md px-3 py-2 mt-1" %>
    </div>

    <div>
      <%= form.label :node_id %>
      <%= form.collection_select :node_id, Node.all, :id, :name, { include_blank: true }, class: "block w-full border rounded-md px-3 py-2 mt-1" %>
    </div>

    <div>
      <%= form.label :title %>
      <%= form.text_field :title, class: "block w-full border rounded-md px-3 py-2 mt-1" %>
    </div>

    <div>
      <%= form.label :description %>
      <%= form.text_area :description, rows: 5, class: "block w-full border rounded-md px-3 py-2 mt-1" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :status %>
        <%= form.select :status, Issue.statuses.keys, {}, class: "block w-full border rounded-md px-3 py-2 mt-1" %>
      </div>

      <div>
        <%= form.label :priority %>
        <%= form.select :priority, Issue.priorities.keys, {}, class: "block w-full border rounded-md px-3 py-2 mt-1" %>
      </div>
    </div>

    <div class="flex gap-2 mt-6">
      <%= form.submit class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-500" %>
      <%= link_to "Cancel", issues_path, class: "px-4 py-2 bg-gray-100 rounded-md hover:bg-gray-200" %>
    </div>
  </div>
<% end %>
