<%= form_with url: kanban_issues_path, method: :get, local: true, data: { turbo_frame: "kanban_board" }, class: "flex flex-wrap gap-4 items-end" do |f| %>
  <div>
    <%= f.label :node_id, "Node", class: "block text-xs font-semibold mb-1" %>
    <%= f.collection_select :node_id, nodes, :id, :name, { include_blank: "All nodes" }, class: "block w-44 border rounded-md px-2 py-1" %>
  </div>
  <div>
    <%= f.label :start_date, "Start Date", class: "block text-xs font-semibold mb-1" %>
    <%= f.date_field :start_date, value: start_date, class: "block w-36 border rounded-md px-2 py-1" %>
  </div>
  <div>
    <%= f.label :end_date, "End Date", class: "block text-xs font-semibold mb-1" %>
    <%= f.date_field :end_date, value: end_date, class: "block w-36 border rounded-md px-2 py-1" %>
  </div>
  <div>
    <%= f.submit "Filter", class: "px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-500" %>
  </div>
<% end %>

