<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-3 mb-2">
  <div class="bg-white border rounded-lg p-4 flex flex-col items-center">
    <div class="text-xs text-gray-500">Total</div>
    <div class="text-2xl font-bold"><%= stats[:total] %></div>
  </div>
  <div class="bg-green-50 border border-green-200 rounded-lg p-4 flex flex-col items-center">
    <div class="text-xs text-green-700">Open</div>
    <div class="text-xl font-bold text-green-700"><%= stats[:open] %></div>
  </div>
  <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 flex flex-col items-center">
    <div class="text-xs text-yellow-700">In Progress</div>
    <div class="text-xl font-bold text-yellow-700"><%= stats[:in_progress] %></div>
  </div>
  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 flex flex-col items-center">
    <div class="text-xs text-blue-700">Resolved</div>
    <div class="text-xl font-bold text-blue-700"><%= stats[:resolved] %></div>
  </div>
  <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 flex flex-col items-center">
    <div class="text-xs text-gray-700">Closed</div>
    <div class="text-xl font-bold text-gray-700"><%= stats[:closed] %></div>
  </div>
  <div class="bg-red-50 border border-red-200 rounded-lg p-4 flex flex-col items-center">
    <div class="text-xs text-red-700">Critical</div>
    <div class="text-xl font-bold text-red-700"><%= stats[:critical] %></div>
  </div>
</div>

