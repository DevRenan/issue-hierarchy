<% content_for :title, "Issues" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 text-green-600 rounded-md inline-block mb-4"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold">Issues</h1>
      <p class="text-sm text-gray-600 mt-1">View all issues across your workspaces</p>
    </div>
    <%= link_to "New issue", new_issue_path, class: "px-3 py-2 bg-blue-600 hover:bg-blue-500 text-white rounded-md font-medium" %>
  </div>

  <div id="issues">
    <% if @issues.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% @issues.each do |issue| %>
          <%= render partial: "issues/issue_card", locals: { issue: issue } %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white border rounded-lg p-8 text-center">
        <p class="text-gray-500 mb-4">No issues yet. Create a node first, then add issues to it.</p>
        <%= link_to "Go to Workspaces", workspaces_path, data: { turbo_frame: "content" }, class: "inline-block px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-500" %>
      </div>
    <% end %>
  </div>
</div>
