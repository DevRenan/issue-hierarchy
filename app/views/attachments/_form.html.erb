<%= form_with(model: attachment, class: "contents") do |form| %>
  <% if attachment.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(attachment.errors.count, "error") %> prohibited this attachment from being saved:</h2>

      <ul class="list-disc ml-6">
        <% attachment.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :issue_id %>
    <%= form.text_field :issue_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": attachment.errors[:issue_id].none?, "border-red-400 focus:outline-red-600": attachment.errors[:issue_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": attachment.errors[:name].none?, "border-red-400 focus:outline-red-600": attachment.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :file_path %>
    <%= form.text_field :file_path, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": attachment.errors[:file_path].none?, "border-red-400 focus:outline-red-600": attachment.errors[:file_path].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
