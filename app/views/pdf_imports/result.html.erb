<div class="max-w-xl mx-auto mt-12 p-8 bg-white rounded shadow">
  <h1 class="text-xl font-bold mb-4">Resumo da Importação</h1>
  <ul class="mb-4">
    <li><strong>Issues importadas:</strong> <%= result.imported %></li>
    <li><strong>Nodes criados:</strong> <%= result.created_nodes %></li>
    <li><strong>Falhas:</strong> <%= result.failed %></li>
  </ul>
  <% if result.errors.any? %>
    <div class="bg-red-50 text-red-600 p-2 rounded mb-2">
      <strong>Erros:</strong>
      <ul>
        <% result.errors.each do |err| %>
          <li><%= err[:error] %> (<%= err[:block].inspect %>)</li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <%= link_to "Nova importação", new_pdf_import_path, class: "text-blue-600 hover:underline" %>
</div>

