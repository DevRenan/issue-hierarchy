<div class="max-w-xl mx-auto mt-12 p-8 bg-white rounded shadow">
  <h1 class="text-xl font-bold mb-4">Importar PDF de Inspeção</h1>
  <%= form_with url: pdf_import_path, method: :post, local: true, multipart: true do |f| %>
    <div class="mb-4">
      <%= f.label :pdf, "Selecione o PDF", class: "block font-semibold mb-2" %>
      <%= f.file_field :pdf, class: "block w-full border rounded px-3 py-2" %>
    </div>
    <%= f.submit "Importar", class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-500" %>
  <% end %>
</div>

