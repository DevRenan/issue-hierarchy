<%= form_with(model: [issue, comment], local: false) do |f| %>
  <div class="space-y-2">
    <div>
      <%= f.text_area :body, rows: 4, placeholder: "Add a comment...", class: "w-full border rounded-md px-3 py-2 text-sm" %>
    </div>

    <div class="flex items-center justify-end gap-2">
      <%= f.submit "Comment", class: "px-3 py-2 bg-blue-600 text-white rounded-md" %>
    </div>
  </div>
<% end %>
