<div class="flex gap-3">
  <div class="flex-shrink-0">
    <div class="h-9 w-9 rounded-full bg-gray-200 flex items-center justify-center text-sm text-gray-700">
      <%= comment.user.try(:initials) || "U" %>
    </div>
  </div>

  <div class="flex-1 bg-gray-50 border rounded-lg p-3">
    <div class="text-xs text-gray-500">
      <strong class="text-gray-800"><%= comment.user.try(:name) || "User" %></strong>
      <span class="mx-2">•</span>
      <span><%= time_ago_in_words(comment.created_at) %> ago</span>
    </div>

    <div class="mt-1 text-sm text-gray-800"><%= simple_format(comment.body) %></div>
  </div>
</div>
